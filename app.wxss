page {
  min-height: 100%;
  background: #f7f9fa;
  color: #1b2129;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-shell {
  padding: 32rpx;
  box-sizing: border-box;
}

.hero-card,
.panel,
.doc-card,
.empty-card,
.form-card,
.profile-card {
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid #e1e5eb;
  border-radius: 32rpx;
  box-shadow: 0 18rpx 48rpx rgba(27, 33, 41, 0.05);
}

.hero-card,
.form-card,
.panel,
.profile-card,
.empty-card {
  padding: 32rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: 1rpx;
}

.page-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #6f7a86;
  line-height: 1.7;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
}

.muted {
  color: #7b8591;
}

.field {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #5f6a75;
}

.field-input,
.field-textarea {
  width: 100%;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #f7f9fa;
  border: 2rpx solid #e1e5eb;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1b2129;
}

.field-input {
  height: 88rpx;
  line-height: 88rpx;
}

.field-textarea {
  padding: 22rpx 24rpx;
  min-height: 220rpx;
  line-height: 1.7;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
}

.primary-btn {
  background: #1b2129;
  color: #fff;
}

.ghost-btn {
  background: #e1e5eb;
  color: #1b2129;
  border: 2rpx solid #e1e5eb;
}

.danger-btn {
  background: #1b2129;
  color: #fff;
  border: 2rpx solid #1b2129;
}

.btn-row {
  margin-top: 32rpx;
  display: flex;
  gap: 20rpx;
}

.btn-row button {
  flex: 1;
}

.link-row {
  margin-top: 24rpx;
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #1b2129;
}
