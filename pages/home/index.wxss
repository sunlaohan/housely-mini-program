page {
  background: #f1f4f6;
}

.home-shell {
  height: 100vh;
  padding: 16rpx 32rpx 220rpx;
  padding-bottom: calc(220rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.home-shell--batch {
  padding-bottom: 220rpx;
  padding-bottom: calc(220rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.share-landing {
  min-height: 100vh;
  padding: 28rpx 28rpx 72rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0) 30%),
    linear-gradient(180deg, #eef4f7 0%, #f6f0e6 54%, #f1f4f6 100%);
}

.share-hero {
  padding: 48rpx 36rpx 110rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #1b2129 0%, #314552 58%, #506d73 100%);
  box-shadow: 0 28rpx 48rpx rgba(27, 33, 41, 0.14);
}

.share-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #f3ede3;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.share-hero__title {
  margin-top: 24rpx;
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.28;
}

.share-hero__subtitle {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 28rpx;
  line-height: 1.7;
}

.share-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
}

.share-tag {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1;
}

.share-cta-card {
  margin: -54rpx 20rpx 0;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 36rpx rgba(27, 33, 41, 0.08);
  backdrop-filter: blur(16rpx);
}

.share-cta-card__hint {
  margin-top: 16rpx;
  color: #66717e;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
}

.share-section {
  margin-top: 28rpx;
  padding: 30rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 32rpx rgba(27, 33, 41, 0.05);
}

.share-section--soft {
  background: rgba(244, 247, 249, 0.92);
}

.share-section__title {
  color: #1b2129;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.share-feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.share-feature-card {
  width: calc((100% - 16rpx) / 2);
  min-height: 220rpx;
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  background: #f7fafb;
  box-sizing: border-box;
}

.share-feature-card__icon-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #ffffff;
}

.share-feature-card__icon {
  width: 34rpx;
  height: 34rpx;
}

.share-feature-card__title {
  margin-top: 18rpx;
  color: #1b2129;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
}

.share-feature-card__description {
  margin-top: 12rpx;
  color: #6d7683;
  font-size: 24rpx;
  line-height: 1.65;
}

.share-scene-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.share-scene-item {
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #ffffff;
  color: #394350;
  font-size: 26rpx;
  line-height: 1.6;
}

.home-search-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0 12rpx;
  gap: 16rpx;
}

.home-search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 68rpx;
  padding: 0 24rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-sizing: border-box;
}

.home-search-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.home-search-input {
  flex: 1;
  min-width: 0;
  height: 44rpx;
  margin-left: 12rpx;
  color: #2e3742;
  font-size: 28rpx;
  line-height: 44rpx;
}

.home-search-input__placeholder {
  margin-left: 8rpx;
  color: #c4c9cf;
  font-size: 28rpx;
  line-height: 44rpx;
}

.home-search-loading,
.home-search-clear {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.home-search-loading {
  border: 3rpx solid rgba(36, 111, 229, 0.16);
  border-top-color: #246fe5;
  border-radius: 50%;
  box-sizing: border-box;
  animation: home-search-spin 0.8s linear infinite;
}

.home-search-clear {
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-search-clear-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

.home-search-cancel {
  flex-shrink: 0;
  color: #7d8793;
  font-size: 28rpx;
  line-height: 44rpx;
}

.home-search-cancel--placeholder {
  visibility: hidden;
}

@keyframes home-search-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.home-toolbar {
  margin-top: 8rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 8rpx;
  box-sizing: content-box;
}

.home-toolbar-title {
  display: flex;
  align-items: center;
}

.home-toolbar-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.home-toolbar-text {
  margin-left: 8rpx;
  color: #2e3742;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 48rpx;
}

.home-toolbar-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 220rpx;
  height: 64rpx;
  justify-content: flex-end;
  flex-shrink: 0;
}

.home-toolbar-actions__placeholder {
  width: 220rpx;
  height: 64rpx;
  opacity: 0;
  pointer-events: none;
}

.home-category-wrap {
  position: relative;
  width: 100%;
  flex-shrink: 0;
  margin: 8rpx 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.home-category-tabs {
  flex: 1;
  width: 0;
  min-width: 0;
  white-space: nowrap;
}

.home-category-tabs__inner {
  display: inline-flex;
  gap: 12rpx;
  min-width: 100%;
  padding: 0 16rpx 4rpx 0;
  box-sizing: border-box;
}

.home-category-tab {
  max-width: 224rpx;
  height: 64rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background: #e9eef2;
  color: #5c6672;
  font-size: 26rpx;
  line-height: 40rpx;
  box-sizing: border-box;
}

.home-category-tab__text {
  display: block;
  max-width: 176rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.home-category-tab--active {
  background: #ffffff;
  color: #246fe5;
  font-weight: 600;
}

.home-category-more {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
  z-index: 2;
}

.home-category-more::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: #f1f4f6;
  z-index: -1;
}

.home-category-more__icon {
  width: 40rpx;
  height: 40rpx;
  display: block;
}

.batch-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 80rpx;
  height: 64rpx;
  padding: 0 16rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-sizing: border-box;
}

.batch-pill--plain {
  min-width: 0;
  padding: 0 18rpx;
}

.batch-pill-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.batch-pill-text {
  margin-left: 8rpx;
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
}

.batch-pill--plain .batch-pill-text {
  margin-left: 0;
}

.add-fab {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1b2129;
  border-radius: 50%;
  flex-shrink: 0;
}

.add-fab-icon {
  width: 28rpx;
  height: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 220rpx;
}

.empty-illustration {
  width: 524rpx;
  height: 302rpx;
}

.empty-copy {
  margin-top: 8rpx;
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
}

.empty-state app-button {
  margin-top: 28rpx;
}

.doc-loading {
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #7b8591;
}

.doc-loading__spinner {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid rgba(36, 111, 229, 0.14);
  border-top-color: #246fe5;
  border-radius: 50%;
  box-sizing: border-box;
  animation: home-search-spin 0.8s linear infinite;
}

.doc-loading__text {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 40rpx;
}

.doc-list {
  margin-top: 20rpx;
}

.home-content-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
  box-sizing: border-box;
}

.doc-list__group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.doc-list__action {
  margin-top: 24rpx;
}

.swipe-shell {
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
  background: transparent;
}

.doc-swipe-actions {
  position: absolute;
  right: 2rpx;
  top: 2rpx;
  bottom: 2rpx;
  width: 224rpx;
  display: flex;
  border-radius: 0 14rpx 14rpx 0;
  overflow: hidden;
}

.doc-swipe-btn {
  width: 112rpx;
  height: 100%;
  margin: 0;
  padding: 0;
  border-radius: 0;
  color: #fff;
  font-size: 28rpx;
  line-height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.doc-swipe-btn::after {
  border: none;
}

.doc-swipe-btn--move {
  background: #246fe5;
}

.doc-swipe-btn--delete {
  background: #f55047;
}

.doc-card {
  width: 100%;
  position: relative;
  z-index: 1;
  padding: 20rpx 32rpx;
  background: #ffffff;
  border: none;
  border-radius: 16rpx;
  box-shadow: none;
  transition: transform 0.2s ease;
  box-sizing: border-box;
}

.doc-card--swiped {
  border-radius: 16rpx 0 0 16rpx;
}

.doc-main {
  display: flex;
  align-items: flex-start;
}

.doc-select-slot {
  display: flex;
  align-items: center;
  padding-right: 8rpx;
  min-height: 44rpx;
}

.doc-select {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #c4c9cf;
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  flex-shrink: 0;
}

.doc-select--checked {
  background: #246fe5;
  border-color: #246fe5;
}

.doc-select__tick {
  width: 14rpx;
  height: 8rpx;
  border-left: 2rpx solid #ffffff;
  border-bottom: 2rpx solid #ffffff;
  transform: rotate(-45deg) translateY(-1rpx);
  box-sizing: border-box;
}

.doc-cover {
  width: 96rpx;
  height: 96rpx;
  margin-right: 20rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f1f4f6;
  flex-shrink: 0;
}

.doc-cover__image,
.doc-cover__placeholder {
  width: 100%;
  height: 100%;
}

.doc-cover__placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef1f4;
}

.doc-cover__placeholder-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.42;
}

.doc-content {
  flex: 1;
  min-width: 0;
}

.doc-title-row {
  display: flex;
  align-items: center;
}

.doc-name {
  flex: 1;
  min-width: 0;
  color: #2e3742;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 44rpx;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.doc-arrow {
  width: 18rpx;
  height: 18rpx;
  margin-left: 8rpx;
  border-top: 2rpx solid #98a1ab;
  border-right: 2rpx solid #98a1ab;
  transform: rotate(45deg);
  box-sizing: border-box;
  flex-shrink: 0;
}

.doc-desc {
  margin-top: 8rpx;
  color: #8b949e;
  font-size: 24rpx;
  line-height: 40rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.batch-footer {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 28rpx;
  bottom: calc(28rpx + constant(safe-area-inset-bottom));
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: flex;
  gap: 20rpx;
}

.batch-footer__move,
.batch-footer__delete {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 44rpx;
  box-sizing: border-box;
}

.batch-footer__move {
  width: 240rpx;
  flex-shrink: 0;
  background: #1b2129;
}

.batch-footer__delete {
  flex: 1;
  min-width: 0;
  padding: 0 24rpx;
  background: #f55047;
}

.batch-footer__button--disabled {
  opacity: 0.48;
}

.home-category-sheet {
  min-height: 52vh;
  max-height: 78vh;
  padding: 0 32rpx 56rpx;
  padding-bottom: calc(56rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #f1f4f6;
  box-sizing: border-box;
  overflow: hidden;
}

.home-category-sheet__header {
  position: relative;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-category-sheet__close {
  position: absolute;
  left: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  color: #424c59;
  font-size: 52rpx;
  line-height: 64rpx;
}

.home-category-sheet__title {
  color: #1b2129;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 48rpx;
}

.home-category-sheet__add {
  position: absolute;
  right: 0;
  min-width: 72rpx;
  color: #246fe5;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: right;
}

.home-category-sheet__scroll {
  max-height: calc(78vh - 160rpx);
}

.home-category-sheet__notice {
  margin-bottom: 16rpx;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #424c59;
  font-size: 26rpx;
  line-height: 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.home-category-sheet__notice-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  opacity: 0.72;
}

.home-category-sheet__list {
  border-radius: 16rpx;
  background: #ffffff;
  overflow: hidden;
}

.home-category-swipe-shell {
  position: relative;
  overflow: hidden;
  background: #ffffff;
  transition: transform 0.18s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.18s ease, border-radius 0.18s ease;
  will-change: transform;
}

.home-category-swipe-shell + .home-category-swipe-shell {
  border-top: 1rpx solid #edf0f3;
}

.home-category-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 240rpx;
  display: flex;
  opacity: 0;
  transition: opacity 0.16s ease;
}

.home-category-swipe-shell--open .home-category-actions {
  opacity: 1;
}

.home-category-swipe-shell--dragging {
  z-index: 5;
  overflow: visible;
  border-radius: 16rpx;
  box-shadow: 0 20rpx 48rpx rgba(27, 33, 41, 0.22);
  transition: box-shadow 0.12s ease, border-radius 0.12s ease;
}

.home-category-action {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 40rpx;
}

.home-category-action--edit {
  background: #246fe5;
}

.home-category-action--delete {
  background: #f55047;
}

.home-category-sheet__row {
  position: relative;
  z-index: 1;
  min-height: 96rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  transition: transform 0.2s ease;
  box-sizing: border-box;
}

.home-category-swipe-shell--dragging .home-category-sheet__row {
  border-radius: 16rpx;
}

.home-category-sheet__row--selected .home-category-sheet__name {
  color: #246fe5;
  font-weight: 600;
}

.home-category-sheet__name {
  flex: 1;
  min-width: 0;
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
  word-break: break-all;
}

.home-category-sheet__drag {
  width: 56rpx;
  height: 56rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9aa3ad;
  font-size: 30rpx;
  line-height: 56rpx;
  flex-shrink: 0;
}

.home-category-sheet__check {
  width: 24rpx;
  height: 14rpx;
  margin-left: 20rpx;
  border-left: 4rpx solid #246fe5;
  border-bottom: 4rpx solid #246fe5;
  transform: rotate(-45deg) translateY(-2rpx);
  box-sizing: border-box;
  flex-shrink: 0;
}

.home-category-dialog {
  position: fixed;
  z-index: 11000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.home-category-dialog__mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.7);
}

.home-category-dialog__panel {
  position: relative;
  width: 100%;
  border-radius: 32rpx;
  overflow: hidden;
  background: #ffffff;
}

.home-category-dialog__content {
  padding: 52rpx 48rpx;
  box-sizing: border-box;
}

.home-category-dialog__title {
  color: #1b2129;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 48rpx;
  text-align: center;
}

.home-category-dialog__tip {
  margin-top: 16rpx;
  color: #626c78;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
}

.home-category-dialog__input {
  width: 100%;
  height: 84rpx;
  margin-top: 16rpx;
  padding: 0 32rpx;
  border-radius: 8rpx;
  background: #f1f4f6;
  color: #424c59;
  font-size: 28rpx;
  line-height: 44rpx;
  box-sizing: border-box;
}

.home-category-dialog__actions {
  height: 96rpx;
  display: flex;
  border-top: 1rpx solid #e8ecf0;
}

.home-category-dialog__button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 48rpx;
}

.home-category-dialog__button + .home-category-dialog__button {
  border-left: 1rpx solid #e8ecf0;
}

.home-category-dialog__button--cancel {
  color: #8b949e;
}

.home-category-dialog__button--confirm {
  color: #246fe5;
}
