<block wx:if="{{shareLandingVisible}}">
  <view class="share-landing">
    <view class="share-hero">
      <view class="share-hero__eyebrow">家物小记</view>
      <view class="share-hero__title">把家里的说明书、票据和户号都存起来</view>
      <view class="share-hero__subtitle">拍一下，自动成文档；想找时，直接搜。</view>

      <view class="share-tag-row">
        <view class="share-tag">家电说明书</view>
        <view class="share-tag">缴费票据</view>
        <view class="share-tag">户号纸条</view>
      </view>
    </view>

    <view class="share-cta-card">
      <app-button text="立即体验" variant="dark" width-mode="full" bind:press="goLogin" />
      <view class="share-cta-card__hint">适合分享给家人、伴侣和室友，一起把家里的常用资料收整齐。</view>
    </view>

    <view class="share-section">
      <view class="share-section__title">你能用它做什么</view>
      <view class="share-feature-grid">
        <block wx:for="{{shareHighlights}}" wx:key="key">
          <view class="share-feature-card">
            <view class="share-feature-card__icon-wrap">
              <image class="share-feature-card__icon" src="{{item.icon}}" mode="aspectFit"></image>
            </view>
            <view class="share-feature-card__title">{{item.title}}</view>
            <view class="share-feature-card__description">{{item.description}}</view>
          </view>
        </block>
      </view>
    </view>

    <view class="share-section share-section--soft">
      <view class="share-section__title">典型场景</view>
      <view class="share-scene-list">
        <block wx:for="{{shareScenes}}" wx:key="*this">
          <view class="share-scene-item">{{item}}</view>
        </block>
      </view>
    </view>
  </view>
</block>

<view wx:else class="page-shell home-shell {{batchMode ? 'home-shell--batch' : ''}}" bindtap="closeSwipe">
  <view class="home-search-row">
    <view class="home-search-box">
      <image class="home-search-icon" src="../../assets/auth/search.svg" mode="aspectFit"></image>
      <input
        class="home-search-input"
        type="text"
        confirm-type="search"
        maxlength="50"
        placeholder="请输入搜索关键词"
        placeholder-class="home-search-input__placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <view wx:if="{{searchLoading}}" class="home-search-loading" catchtap="noop"></view>
      <view wx:elif="{{searchKeyword}}" class="home-search-clear" catchtap="clearSearch">
        <image class="home-search-clear-icon" src="../../assets/auth/cross.svg" mode="aspectFit"></image>
      </view>
    </view>
    <view wx:if="{{searchKeyword}}" class="home-search-cancel" bindtap="cancelSearch">取消</view>
    <view wx:else class="home-search-cancel home-search-cancel--placeholder"></view>
  </view>

  <view class="home-toolbar">
    <view class="home-toolbar-title">
      <image class="home-toolbar-icon" src="../../assets/auth/description.svg" mode="aspectFit"></image>
      <text class="home-toolbar-text">记忆列表 ({{docs.length}})</text>
    </view>

    <view class="home-toolbar-actions">
      <block wx:if="{{batchMode}}">
        <view class="batch-pill batch-pill--plain" bindtap="toggleSelectAll">
          <text class="batch-pill-text">{{allVisibleSelected ? '取消全选' : '全选'}}</text>
        </view>
        <view class="batch-pill batch-pill--plain" bindtap="exitBatchMode">
          <text class="batch-pill-text">取消批量</text>
        </view>
      </block>
      <view wx:if="{{!batchMode && docs.length}}" class="batch-pill" bindtap="toggleBatch">
        <image class="batch-pill-icon" src="../../assets/auth/passed.svg" mode="aspectFit"></image>
        <text class="batch-pill-text">批量操作</text>
      </view>
      <view wx:if="{{!batchMode && docs.length}}" class="add-fab" bindtap="goAdd">
        <image class="add-fab-icon" src="../../assets/auth/plus.svg" mode="aspectFit"></image>
      </view>
      <view wx:if="{{!batchMode && !docs.length}}" class="home-toolbar-actions__placeholder"></view>
    </view>
  </view>

  <view wx:if="{{allDocs.length && categories.length}}" class="home-category-wrap home-category-wrap--more">
    <scroll-view
      class="home-category-tabs"
      scroll-x
      enhanced
      show-scrollbar="{{false}}"
      scroll-left="{{categoryScrollTargetLeft}}"
      scroll-into-view="{{categoryScrollIntoView}}"
      scroll-with-animation
      bindscroll="onCategoryTabsScroll"
    >
      <view class="home-category-tabs__inner">
        <block wx:for="{{categories}}" wx:key="id">
          <view
            id="category-tab-{{item.id}}"
            class="home-category-tab {{selectedCategoryId === item.id ? 'home-category-tab--active' : ''}}"
            data-id="{{item.id}}"
            bindtap="switchCategory"
          >
            <text class="home-category-tab__text">{{item.name}}</text>
          </view>
        </block>
      </view>
    </scroll-view>

    <view class="home-category-more" catchtap="openCategoryChooser">
      <image class="home-category-more__icon" src="../../assets/auth/wap-nav.svg" mode="aspectFit"></image>
    </view>
  </view>

  <scroll-view
    class="home-content-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled="{{currentUser && !shareLandingVisible}}"
    refresher-triggered="{{contentRefreshing}}"
    bindrefresherrefresh="onListRefresh"
  >
    <block wx:if="{{isLoadingDocs}}">
      <view class="doc-loading">
        <view class="doc-loading__spinner"></view>
        <view class="doc-loading__text">正在加载文件</view>
      </view>
    </block>

    <block wx:elif="{{!docs.length}}">
      <view class="empty-state">
        <image class="empty-illustration" src="../../assets/auth/empty-img.png" mode="aspectFit"></image>
        <view class="empty-copy">{{searchKeyword ? '没有匹配到相关内容' : '我的家空无一物'}}</view>
        <app-button wx:if="{{!searchKeyword}}" text="添加" variant="dark" width-mode="fixed" fixed-width="240rpx" bind:press="goAdd" />
      </view>
    </block>

    <block wx:else>
      <view class="doc-list">
        <view class="doc-list__group">
          <block wx:for="{{docs}}" wx:key="id">
            <view class="swipe-shell" catchtap="noop" data-id="{{item.id}}" bindtouchstart="onTouchStart" bindtouchmove="onTouchMove" bindtouchend="onTouchEnd">
              <view class="doc-swipe-actions">
                <button class="doc-swipe-btn doc-swipe-btn--move" data-id="{{item.id}}" catchtap="openMoveCategoryChooser">移动</button>
                <button class="doc-swipe-btn doc-swipe-btn--delete" data-id="{{item.id}}" catchtap="confirmDelete">删除</button>
              </view>

              <view class="doc-card {{item.swipeOffset ? 'doc-card--swiped' : ''}}" style="transform: translateX(-{{item.swipeOffset || 0}}rpx);" data-id="{{item.id}}" bindtap="openDoc">
                <view class="doc-main">
                  <view wx:if="{{batchMode}}" class="doc-select-slot" data-id="{{item.id}}" catchtap="toggleDocSelection">
                    <view class="doc-select {{item.selected ? 'doc-select--checked' : ''}}">
                      <view wx:if="{{item.selected}}" class="doc-select__tick"></view>
                    </view>
                  </view>
                  <view wx:if="{{item.coverFileId}}" class="doc-cover">
                    <image wx:if="{{item.coverUrl}}" class="doc-cover__image" src="{{item.coverUrl}}" mode="aspectFill"></image>
                    <view wx:else class="doc-cover__placeholder">
                      <image class="doc-cover__placeholder-icon" src="../../assets/auth/photograph.svg" mode="aspectFit"></image>
                    </view>
                  </view>
                  <view class="doc-content">
                    <view class="doc-title-row">
                      <rich-text class="doc-name" nodes="{{item.titleRichText}}"></rich-text>
                      <view class="doc-arrow"></view>
                    </view>
                    <view class="doc-desc">{{item.previewText || '暂无正文内容'}}</view>
                  </view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </block>
  </scroll-view>

  <view wx:if="{{batchMode && docs.length}}" class="batch-footer">
    <view class="batch-footer__move {{selectedIds.length ? '' : 'batch-footer__button--disabled'}}" bindtap="openBatchMoveCategoryChooser">移动</view>
    <view class="batch-footer__delete {{selectedIds.length ? '' : 'batch-footer__button--disabled'}}" bindtap="deleteSelected">{{deleteSelectedText}}</view>
  </view>

  <bottom-sheet visible="{{categoryChooserVisible}}" bind:close="closeCategoryChooser">
    <view class="home-category-sheet">
      <view class="home-category-sheet__header">
        <view class="home-category-sheet__close" bindtap="closeCategoryChooser">×</view>
        <view class="home-category-sheet__title">{{categoryChooserMode === 'move' ? '选择分类' : '快速切换分类'}}</view>
        <view wx:if="{{categoryChooserMode !== 'move'}}" class="home-category-sheet__add" bindtap="openHomeNewCategoryDialog">新增</view>
      </view>

      <scroll-view class="home-category-sheet__scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:if="{{categoryChooserMode !== 'move'}}" class="home-category-sheet__notice">
          <image class="home-category-sheet__notice-icon" src="../../assets/auth/info-o.svg" mode="aspectFit" />
          <text>左滑可编辑/删除分类，默认分类不支持</text>
        </view>
        <view class="home-category-sheet__list">
          <block wx:for="{{categories}}" wx:key="id">
            <view
              class="home-category-swipe-shell {{item.swipeOffset ? 'home-category-swipe-shell--open' : ''}}"
              data-id="{{item.id}}"
              bindtouchstart="onHomeCategoryTouchStart"
              bindtouchmove="onHomeCategoryTouchMove"
              bindtouchend="onHomeCategoryTouchEnd"
              bindtouchcancel="onHomeCategoryTouchEnd"
            >
              <view wx:if="{{categoryChooserMode !== 'move' && !item.isDefault}}" class="home-category-actions">
                <view class="home-category-action home-category-action--edit" data-id="{{item.id}}" catchtap="openHomeCategoryEditDialog">编辑</view>
                <view class="home-category-action home-category-action--delete" data-id="{{item.id}}" catchtap="confirmHomeDeleteCategory">删除</view>
              </view>
              <view
                class="home-category-sheet__row {{(categoryChooserMode === 'move' ? moveCategoryId : selectedCategoryId) === item.id ? 'home-category-sheet__row--selected' : ''}}"
                style="transform: translateX(-{{categoryChooserMode === 'move' ? 0 : (item.swipeOffset || 0)}}rpx);"
                data-id="{{item.id}}"
                bindtap="chooseCategoryFromSheet"
              >
                <text class="home-category-sheet__name">{{item.name}}</text>
                <view wx:if="{{(categoryChooserMode === 'move' ? moveCategoryId : selectedCategoryId) === item.id}}" class="home-category-sheet__check"></view>
              </view>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>
  </bottom-sheet>

  <view wx:if="{{categoryEditDialogVisible}}" class="home-category-dialog" catchtouchmove="noop">
    <view class="home-category-dialog__mask" catchtap="closeHomeCategoryDialog"></view>
    <view class="home-category-dialog__panel" catchtap="noop">
      <view class="home-category-dialog__content">
        <view class="home-category-dialog__title">{{categoryEditId ? '编辑分类' : '新增分类'}}</view>
        <view class="home-category-dialog__tip">分类最多支持16个字符超出无法输入</view>
        <input
          class="home-category-dialog__input"
          value="{{categoryEditName}}"
          focus="{{categoryEditFocus}}"
          maxlength="16"
          confirm-type="done"
          bindinput="onHomeCategoryDialogInput"
          bindconfirm="confirmHomeCategoryDialog"
        />
      </view>
      <view class="home-category-dialog__actions">
        <view class="home-category-dialog__button home-category-dialog__button--cancel" catchtap="closeHomeCategoryDialog">取消</view>
        <view class="home-category-dialog__button home-category-dialog__button--confirm" catchtap="confirmHomeCategoryDialog">确定</view>
      </view>
    </view>
  </view>
</view>
