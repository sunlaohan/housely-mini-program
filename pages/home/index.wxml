<block wx:if="{{shareLandingVisible}}">
  <view class="share-landing">
    <view class="share-hero">
      <view class="share-hero__eyebrow">家物小记</view>
      <view class="share-hero__title">把家里的说明书、票据和户号都存起来</view>
      <view class="share-hero__subtitle">拍一下，自动成文档；想找时，直接搜。</view>

      <view class="share-tag-row">
        <view class="share-tag">家电说明书</view>
        <view class="share-tag">缴费票据</view>
        <view class="share-tag">户号纸条</view>
      </view>
    </view>

    <view class="share-cta-card">
      <app-button text="立即体验" variant="dark" width-mode="full" bind:press="goLogin" />
      <view class="share-cta-card__hint">适合分享给家人、伴侣和室友，一起把家里的常用资料收整齐。</view>
    </view>

    <view class="share-section">
      <view class="share-section__title">你能用它做什么</view>
      <view class="share-feature-grid">
        <block wx:for="{{shareHighlights}}" wx:key="key">
          <view class="share-feature-card">
            <view class="share-feature-card__icon-wrap">
              <image class="share-feature-card__icon" src="{{item.icon}}" mode="aspectFit"></image>
            </view>
            <view class="share-feature-card__title">{{item.title}}</view>
            <view class="share-feature-card__description">{{item.description}}</view>
          </view>
        </block>
      </view>
    </view>

    <view class="share-section share-section--soft">
      <view class="share-section__title">典型场景</view>
      <view class="share-scene-list">
        <block wx:for="{{shareScenes}}" wx:key="*this">
          <view class="share-scene-item">{{item}}</view>
        </block>
      </view>
    </view>
  </view>
</block>

<view wx:else class="page-shell home-shell {{batchMode ? 'home-shell--batch' : ''}}" bindtap="closeSwipe">
  <view class="home-search-row">
    <view class="home-search-box">
      <image class="home-search-icon" src="../../assets/auth/search.svg" mode="aspectFit"></image>
      <input
        class="home-search-input"
        type="text"
        confirm-type="search"
        maxlength="50"
        placeholder="请输入搜索关键词"
        placeholder-class="home-search-input__placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <view wx:if="{{searchLoading}}" class="home-search-loading" catchtap="noop"></view>
      <view wx:elif="{{searchKeyword}}" class="home-search-clear" catchtap="clearSearch">
        <image class="home-search-clear-icon" src="../../assets/auth/cross.svg" mode="aspectFit"></image>
      </view>
    </view>
    <view wx:if="{{searchKeyword}}" class="home-search-cancel" bindtap="cancelSearch">取消</view>
    <view wx:else class="home-search-cancel home-search-cancel--placeholder"></view>
  </view>

  <view class="home-toolbar">
    <view class="home-toolbar-title">
      <image class="home-toolbar-icon" src="../../assets/auth/description.svg" mode="aspectFit"></image>
      <text class="home-toolbar-text">记忆列表 ({{searchKeyword ? docs.length : allDocs.length}})</text>
    </view>

    <view class="home-toolbar-actions">
      <block wx:if="{{batchMode}}">
        <view class="batch-pill batch-pill--plain" bindtap="toggleSelectAll">
          <text class="batch-pill-text">{{allVisibleSelected ? '取消全选' : '全选'}}</text>
        </view>
        <view class="batch-pill batch-pill--plain" bindtap="exitBatchMode">
          <text class="batch-pill-text">取消批量</text>
        </view>
      </block>
      <view wx:if="{{!batchMode && docs.length}}" class="batch-pill" bindtap="toggleBatch">
        <image class="batch-pill-icon" src="../../assets/auth/passed.svg" mode="aspectFit"></image>
        <text class="batch-pill-text">批量操作</text>
      </view>
      <view wx:if="{{!batchMode && docs.length}}" class="add-fab" bindtap="goAdd">
        <image class="add-fab-icon" src="../../assets/auth/plus.svg" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <scroll-view
    class="home-content-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled="{{currentUser && !shareLandingVisible}}"
    refresher-triggered="{{contentRefreshing}}"
    bindrefresherrefresh="onListRefresh"
  >
    <block wx:if="{{isLoadingDocs}}">
      <view class="doc-loading">
        <view class="doc-loading__spinner"></view>
        <view class="doc-loading__text">正在加载文件</view>
      </view>
    </block>

    <block wx:elif="{{!docs.length}}">
      <view class="empty-state">
        <image class="empty-illustration" src="../../assets/auth/empty-img.png" mode="aspectFit"></image>
        <view class="empty-copy">{{searchKeyword ? '没有匹配到相关内容' : '我的家空无一物'}}</view>
        <app-button wx:if="{{!searchKeyword}}" text="添加" variant="dark" width-mode="fixed" fixed-width="240rpx" bind:press="goAdd" />
      </view>
    </block>

    <block wx:else>
      <view class="doc-list">
        <view class="doc-list__group">
          <block wx:for="{{docs}}" wx:key="id">
            <view class="swipe-shell" catchtap="noop" data-id="{{item.id}}" bindtouchstart="onTouchStart" bindtouchmove="onTouchMove" bindtouchend="onTouchEnd">
              <view class="delete-action">
                <button class="delete-btn" data-id="{{item.id}}" bindtap="confirmDelete">删除</button>
              </view>

              <view class="doc-card {{item.swipeOffset ? 'doc-card--swiped' : ''}}" style="transform: translateX(-{{item.swipeOffset || 0}}rpx);" data-id="{{item.id}}" bindtap="openDoc">
                <view class="doc-main">
                  <view wx:if="{{batchMode}}" class="doc-select-slot" data-id="{{item.id}}" catchtap="toggleDocSelection">
                    <view class="doc-select {{item.selected ? 'doc-select--checked' : ''}}">
                      <view wx:if="{{item.selected}}" class="doc-select__tick"></view>
                    </view>
                  </view>
                  <view class="doc-content">
                    <view class="doc-title-row">
                      <rich-text class="doc-name" nodes="{{item.titleRichText}}"></rich-text>
                      <view class="doc-arrow"></view>
                    </view>
                    <view class="doc-desc">{{item.previewText || '暂无正文内容'}}</view>
                  </view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </block>
  </scroll-view>

  <view wx:if="{{batchMode && docs.length}}" class="batch-footer">
    <app-button text="{{deleteSelectedText}}" variant="danger" width-mode="full" bind:press="deleteSelected" />
  </view>
</view>
