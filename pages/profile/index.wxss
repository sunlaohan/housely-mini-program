page {
  background: #f1f4f6;
}

.profile-page {
  min-height: 100vh;
  background: #f1f4f6;
}

.profile-navbar {
  background: #f1f4f6;
}

.profile-navbar__bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 28rpx;
  padding-right: 28rpx;
  box-sizing: border-box;
}

.profile-navbar__spacer {
  width: 156rpx;
  height: 100%;
  flex-shrink: 0;
}

.profile-navbar__title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 320rpx;
  color: #1b2129;
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 600;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-navbar__capsule {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 156rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.profile-navbar__capsule-inner {
  width: 120rpx;
  height: 56rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(241, 244, 246, 0.9);
}

.profile-navbar__capsule-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #1b2129;
}

.profile-navbar__capsule-divider {
  width: 2rpx;
  height: 18rpx;
  margin: 0 2rpx 0 6rpx;
  border-radius: 999rpx;
  background: #e8ecf0;
}

.profile-navbar__capsule-ring {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 3rpx solid #1b2129;
  box-sizing: border-box;
  position: relative;
}

.profile-navbar__capsule-ring::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #1b2129;
  transform: translate(-50%, -50%);
}

.profile-body {
  min-height: calc(100vh - 90px);
  padding: 56rpx 32rpx 248rpx;
  padding-bottom: calc(248rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(248rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.profile-user {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 22rpx;
}

.profile-avatar {
  width: 244rpx;
  height: 244rpx;
  border-radius: 50%;
  display: block;
  background: #ffffff;
}

.profile-name {
  margin-top: 28rpx;
  color: #2e3742;
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 600;
  text-align: center;
}

.profile-section {
  margin-top: 84rpx;
  width: 100%;
  box-sizing: border-box;
}

.profile-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  border: none;
  box-shadow: none;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.profile-card--list {
  box-shadow: none;
}

.profile-logout-wrap {
  margin-top: 16rpx;
}

.profile-logout-wrap app-button,
.feedback-sheet__footer app-button {
  width: 100%;
}

.avatar-sheet {
  width: 100%;
  height: calc(100vh - 192rpx);
  min-height: calc(100vh - 192rpx);
  max-height: calc(100vh - 192rpx);
  background: #f1f4f6;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.avatar-sheet__header {
  height: 92rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.avatar-sheet__close,
.avatar-sheet__placeholder {
  width: 156rpx;
  height: 100%;
  flex-shrink: 0;
}

.avatar-sheet__close {
  display: flex;
  align-items: center;
}

.avatar-sheet__close-icon {
  width: 44rpx;
  height: 44rpx;
}

.avatar-sheet__title {
  flex: 1;
  color: #1b2129;
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 600;
  text-align: center;
}

.avatar-sheet__body {
  display: flex;
  flex-wrap: wrap;
  gap: 48rpx;
  padding: 32rpx 32rpx 0;
  box-sizing: border-box;
}

.avatar-sheet__item {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #ffffff;
  box-sizing: border-box;
}

.avatar-sheet__item--selected {
  border: 4rpx solid #1b2129;
}

.avatar-sheet__item--custom {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e1e5eb;
}

.avatar-sheet__image {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-sheet__local-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #1b2129;
  font-size: 32rpx;
  line-height: 40rpx;
  font-weight: 600;
}

.avatar-sheet__footer {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 16rpx 32rpx 32rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.avatar-sheet__footer app-button {
  width: 100%;
}

.avatar-sheet__wechat-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.avatar-sheet__wechat-text {
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
}

.feedback-sheet {
  width: 100%;
  height: calc(100vh - 192rpx);
  min-height: calc(100vh - 192rpx);
  max-height: calc(100vh - 192rpx);
  background: #f1f4f6;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.feedback-sheet__header {
  height: 92rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.feedback-sheet__close,
.feedback-sheet__placeholder {
  width: 156rpx;
  height: 100%;
  flex-shrink: 0;
}

.feedback-sheet__close {
  display: flex;
  align-items: center;
}

.feedback-sheet__close-icon {
  width: 44rpx;
  height: 44rpx;
}

.feedback-sheet__title {
  flex: 1;
  color: #1b2129;
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 600;
  text-align: center;
}

.feedback-sheet__body {
  flex: 1;
  min-height: 0;
  padding: 32rpx 32rpx 0;
  box-sizing: border-box;
}

.feedback-sheet__card {
  overflow: hidden;
  border-radius: 16rpx;
  background: #ffffff;
}

.feedback-sheet__footer {
  margin-top: auto;
  padding: 24rpx 32rpx 32rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.about-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(0, 0, 0, 0);
  transition: background 0.3s ease;
}

.about-mask--show {
  background: rgba(0, 0, 0, 0.7);
}

.about-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 192rpx;
  background: #f7f9fa;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.about-panel--show {
  transform: translateY(0);
}

.about-navbar {
  display: flex;
  align-items: center;
  height: 92rpx;
  flex-shrink: 0;
}

.about-navbar__left {
  width: 156rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  padding-left: 32rpx;
  box-sizing: border-box;
}

.about-close-icon {
  width: 44rpx;
  height: 44rpx;
}

.about-navbar__title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 48rpx;
  color: #1b2129;
}

.about-navbar__right {
  width: 156rpx;
  height: 92rpx;
}

.about-scroll {
  flex: 1;
  height: 0;
  padding: 32rpx 48rpx 0;
  box-sizing: border-box;
}

.about-video-wrap {
  position: relative;
  width: 100%;
  height: 436rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.about-video {
  width: 100%;
  height: 100%;
}

.about-video-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.about-video-overlay__button {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
}

.about-video-overlay__triangle {
  width: 0;
  height: 0;
  margin-left: 6rpx;
  border-top: 16rpx solid transparent;
  border-bottom: 16rpx solid transparent;
  border-left: 26rpx solid #ffffff;
}

.about-text {
  padding: 32rpx 0 80rpx;
  word-wrap: break-word;
  word-break: break-all;
}

.about-text text {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.57;
  color: #626c78;
}
