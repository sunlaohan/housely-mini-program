<view class="page-shell">
  <view class="hero-card">
    <view class="page-title">修改密码</view>
    <view class="page-subtitle">输入当前密码后设置新的登录密码。</view>
  </view>

  <view class="form-card" style="margin-top: 28rpx;">
    <view class="field">
      <text class="field-label">当前密码</text>
      <input class="field-input" password placeholder="请输入当前密码" data-field="oldPassword" bindinput="onInput" value="{{oldPassword}}" />
    </view>

    <view class="field">
      <text class="field-label">新密码</text>
      <input class="field-input" password placeholder="请输入新密码" data-field="nextPassword" bindinput="onInput" value="{{nextPassword}}" />
    </view>

    <view class="field">
      <text class="field-label">确认新密码</text>
      <input class="field-input" password placeholder="请再次输入新密码" data-field="confirmPassword" bindinput="onInput" value="{{confirmPassword}}" />
    </view>

    <button class="primary-btn" style="margin-top: 32rpx;" bindtap="submit">确认修改</button>
  </view>
</view>
