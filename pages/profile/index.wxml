<view class="profile-page">
  <view class="profile-navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="profile-navbar__bar" style="height: {{navBarHeight}}px; padding-right: {{capsuleSafeWidth}}px;">
      <view class="profile-navbar__spacer"></view>
      <view class="profile-navbar__title">家物小记</view>
    </view>
  </view>

  <view wx:if="{{currentUser}}" class="profile-body">
    <view class="profile-user" bindtap="pickAvatar">
      <image class="profile-avatar" src="{{currentUser.avatar || defaultAvatar}}" mode="aspectFill" catchtap="pickAvatar"></image>
      <view class="profile-name" catchtap="pickAvatar">{{currentUser.username}}</view>
    </view>

    <view class="profile-section">
      <view class="profile-card profile-card--list">
        <list-cell title="关于家物小记" show-divider="{{true}}" bind:press="showAbout" />
        <list-cell title="意见反馈" show-divider="{{true}}" bind:press="showFeedback" />
        <list-cell title="注销账号" danger="{{true}}" show-divider="{{false}}" bind:press="removeAccount" />
      </view>

      <view class="profile-logout-wrap">
        <app-button text="退出登录" variant="light" width-mode="full" bind:press="logoutAccount" />
      </view>
    </view>
  </view>

  <view wx:else class="profile-body profile-body--guest">
    <view class="profile-user profile-user--guest">
      <image class="profile-avatar profile-avatar--guest" src="{{defaultAvatar}}" mode="aspectFill"></image>
      <view class="profile-name profile-name--guest">{{guestName}}</view>
    </view>

    <view class="profile-guest-section">
      <view class="profile-login-card">
        <text>未登录前我们无法存下你的记忆哦～\n立即登录，记下家里重要的一切吧～</text>
      </view>
      <app-button text="立即登录" variant="dark" width-mode="full" bind:press="goLogin" />
    </view>
  </view>

  <bottom-sheet wx:if="{{currentUser}}" visible="{{feedbackVisible}}" bind:close="closeFeedbackPanel">
    <view class="feedback-sheet">
      <view class="feedback-sheet__header">
        <view class="feedback-sheet__close" bindtap="closeFeedbackPanel">
          <image class="feedback-sheet__close-icon" src="../../assets/auth/cross.svg" mode="aspectFit"></image>
        </view>
        <view class="feedback-sheet__title">意见反馈</view>
        <view class="feedback-sheet__placeholder"></view>
      </view>

      <view class="feedback-sheet__body">
        <view class="feedback-sheet__card">
          <form-textarea
            label="问题描述"
            required="{{true}}"
            placeholder="请输入"
            value="{{feedbackForm.content}}"
            maxlength="200"
            show-divider="{{true}}"
            disabled="{{feedbackSubmitting}}"
            bind:change="onFeedbackContentChange"
          />
          <media-uploader
            label="问题图片/视频"
            items="{{feedbackForm.attachments}}"
            max-count="{{feedbackMaxCount}}"
            add-icon="/assets/auth/photograph.svg"
            disabled="{{feedbackSubmitting}}"
            bind:add="addFeedbackAttachment"
            bind:remove="removeFeedbackAttachment"
            bind:preview="previewFeedbackAttachment"
          />
        </view>
      </view>

      <view class="feedback-sheet__footer">
        <app-button text="确定" variant="dark" width-mode="full" disabled="{{feedbackSubmitting}}" bind:press="submitFeedbackForm" />
      </view>
    </view>
  </bottom-sheet>

  <bottom-sheet visible="{{avatarPanelVisible}}" bind:close="closeAvatarPanel">
    <view class="avatar-sheet">
      <view class="avatar-sheet__header">
        <view class="avatar-sheet__close" bindtap="closeAvatarPanel">
          <image class="avatar-sheet__close-icon" src="../../assets/auth/cross.svg" mode="aspectFit"></image>
        </view>
        <view class="avatar-sheet__title">更换头像</view>
        <view class="avatar-sheet__placeholder"></view>
      </view>

      <view class="avatar-sheet__body">
        <view
          wx:for="{{avatarBuiltinOptions}}"
          wx:key="key"
          class="avatar-sheet__item {{avatarSelectionKey === item.key ? 'avatar-sheet__item--selected' : ''}}"
          data-key="{{item.key}}"
          data-src="{{item.src}}"
          bindtap="chooseBuiltinAvatar"
        >
          <image class="avatar-sheet__image" src="{{item.src}}" mode="aspectFill"></image>
        </view>

        <view
          class="avatar-sheet__item avatar-sheet__item--custom {{avatarSelectionKey === 'custom' ? 'avatar-sheet__item--selected' : ''}}"
          bindtap="chooseLocalAvatar"
        >
          <block wx:if="{{avatarDraftCustomSrc}}">
            <image class="avatar-sheet__image" src="{{avatarDraftCustomSrc}}" mode="aspectFill"></image>
          </block>
          <view wx:else class="avatar-sheet__local-placeholder">
            <text>本地</text>
            <text>照片</text>
          </view>
        </view>
      </view>

      <view class="avatar-sheet__footer">
        <app-button variant="light" width-mode="full" open-type="chooseAvatar" bind:chooseavatar="onChooseWechatAvatar">
          <image slot="prefix" class="avatar-sheet__wechat-icon" src="../../assets/auth/wechat.svg" mode="aspectFit" />
          <text class="avatar-sheet__wechat-text">获取微信头像</text>
        </app-button>
        <app-button text="确定" variant="dark" width-mode="full" loading="{{avatarSaving}}" disabled="{{avatarSaving}}" bind:press="confirmAvatarSelection" />
      </view>
    </view>
  </bottom-sheet>

  <view class="about-mask {{aboutVisible ? 'about-mask--show' : ''}}" wx:if="{{aboutShow}}" bindtap="hideAbout">
    <view class="about-panel {{aboutVisible ? 'about-panel--show' : ''}}" catchtap="noop">
      <view class="about-navbar">
        <view class="about-navbar__left" bindtap="hideAbout">
          <image class="about-close-icon" src="../../assets/auth/cross.svg" mode="aspectFit" />
        </view>
        <view class="about-navbar__title">关于家物小记</view>
        <view class="about-navbar__right"></view>
      </view>

      <scroll-view class="about-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="about-video-wrap">
          <video
            wx:if="{{aboutVideoReady}}"
            id="profile-about-video"
            class="about-video"
            src="{{aboutVideoUrl}}"
            poster="{{aboutPosterUrl}}"
            controls="{{true}}"
            show-center-play-btn="{{true}}"
            enable-play-gesture="{{true}}"
            object-fit="cover"
            bindplay="onAboutVideoPlay"
            bindpause="onAboutVideoPause"
            bindended="onAboutVideoEnded"
          />
          <view wx:if="{{aboutVideoReady && !aboutVideoPlaying}}" class="about-video-overlay" catchtap="playAboutVideo">
            <view class="about-video-overlay__button">
              <view class="about-video-overlay__triangle"></view>
            </view>
          </view>
          <image wx:else class="about-video" src="{{aboutPosterUrl || '../../assets/auth/img-login.png'}}" mode="aspectFill" />
        </view>

        <view class="about-text">
          <text>亲爱的朋友，你是否在生活中有过这样的场景：\n\n“诶？我们家的用电户号是多少来着？我记得之前办理开户时那个单子上有，但那个单子放哪儿去了？”\n\n“诶？我们家那个车位产权证号是多少来着？还有车位详细产权地址是什么？办理这个业务要咋这么多信息？我现在上哪儿找去？”\n\n“这里要填车架号，车架号不行驶证上才有么？但行驶证在家里咋弄呢？”\n\n“这热水器出问题了，报错E1是什么意思呀？之前热水器的说明书放哪儿去了？”\n\n“这一抽屉的说明书太碍事儿了，平时又不用，要用了又要找很久，找到还要翻阅很久，太麻烦了”\n\n“诶？我们家毛毛当时从宠物店抱回来时那个出生证呢？我想看下他出生日期”\n\n............\n\n现在有了【家物小记】这些问题都能轻松解决，你只需要把他们拍下来，识别一下，一个图文并茂的专属记忆就存下来了。\n你可以随时查看，还能通过搜索在记忆列表、记忆详情中快速找到你想要的内容～～</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
