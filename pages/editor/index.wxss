.scan-summary {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7f9fa;
  border: 2rpx solid #e1e5eb;
}

.ocr-status-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7f9fa;
  border: 2rpx solid #e1e5eb;
}

.ocr-status-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.scan-chip {
  display: inline-flex;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #1b2129;
  background: #e1e5eb;
}

.ocr-status-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-uploading,
.status-created,
.status-polling,
.status-pending {
  color: #1b2129;
  background: #e1e5eb;
}

.status-success {
  color: #ffffff;
  background: #1b2129;
}

.status-failed {
  color: #ffffff;
  background: #4b5563;
}

.ocr-status-text {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #1b2129;
}

.ocr-task-id {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7b8591;
  word-break: break-all;
}

.ocr-refresh-btn {
  margin-top: 24rpx;
}
