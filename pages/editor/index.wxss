.editor-page {
  min-height: 100vh;
  background: #f1f4f6;
}

.editor-navbar {
  position: fixed;
  z-index: 20;
  top: 0;
  left: 0;
  right: 0;
  background: #f1f4f6;
}

.editor-navbar__bar {
  position: relative;
  display: flex;
  align-items: center;
  padding-left: 16px;
  box-sizing: border-box;
}

.editor-navbar__back {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  position: relative;
  z-index: 2;
}

.editor-navbar__back-icon {
  width: 44rpx;
  height: 44rpx;
}

.editor-navbar__title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 300rpx;
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 600;
  color: #1b2129;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.editor-body {
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 48rpx;
  box-sizing: border-box;
}

.editor-body::before {
  content: '';
  display: block;
  height: 24rpx;
}

.editor-body > view + view {
  margin-top: 16rpx;
}

.editor-upload-card,
.editor-field-card,
.editor-category-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 32rpx;
  box-sizing: border-box;
}

.editor-upload-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.editor-section-title,
.editor-field-card__label {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 28rpx;
  line-height: 44rpx;
  color: #424c59;
}

.editor-field-card__required {
  color: #f55047;
}

.editor-upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.editor-upload-trigger,
.editor-upload-preview {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.editor-upload-preview {
  transform: scale(1);
  transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.18s ease, box-shadow 0.18s ease;
  will-change: transform;
}

.editor-upload-trigger {
  background: #f1f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.editor-upload-trigger__icon {
  width: 48rpx;
  height: 48rpx;
}

.editor-upload-preview__image {
  width: 100%;
  height: 100%;
  display: block;
}

.editor-upload-preview--dragging {
  z-index: 2;
  opacity: 0.94;
  box-shadow: 0 16rpx 34rpx rgba(27, 33, 41, 0.22);
  transition: opacity 0.16s ease, box-shadow 0.16s ease;
}

.editor-upload-preview__cover-label {
  position: absolute;
  top: 0;
  right: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 0 0 0 8rpx;
  background: rgba(27, 33, 41, 0.82);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 28rpx;
  box-sizing: border-box;
}

.editor-upload-preview__remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 28rpx;
  height: 28rpx;
}

.editor-upload-tip {
  font-size: 24rpx;
  line-height: 38rpx;
  color: #7b8591;
}

.editor-scan-btn__icon {
  width: 36rpx;
  height: 36rpx;
}

.editor-status {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.editor-status__text {
  display: block;
  font-size: 24rpx;
  line-height: 38rpx;
  color: #7b8591;
}

.editor-field-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.editor-field-card__input {
  width: 100%;
  height: 44rpx;
  border: none;
  padding: 0;
  background: transparent;
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
  box-sizing: border-box;
}

.editor-field-card__textarea {
  display: block;
  width: 100%;
  min-height: 520rpx;
  padding: 0;
  overflow: visible;
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
  white-space: pre-wrap;
  word-break: break-all;
  caret-color: #1b2129;
  box-sizing: border-box;
}

.editor-field-card__placeholder {
  color: #c4c9cf;
}

.editor-field-card--textarea {
  min-height: 628rpx;
}

.editor-category-card {
  padding-top: 0;
  padding-bottom: 0;
}

.editor-category-row {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.editor-category-label {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: #424c59;
  font-size: 28rpx;
  line-height: 44rpx;
}

.editor-category-value {
  display: flex;
  align-items: center;
  max-width: 420rpx;
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
}

.editor-category-value text {
  display: block;
  max-width: 360rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.editor-category-arrow {
  width: 18rpx;
  height: 18rpx;
  margin-left: 12rpx;
  border-top: 2rpx solid #98a1ab;
  border-right: 2rpx solid #98a1ab;
  transform: rotate(45deg);
  box-sizing: border-box;
  flex-shrink: 0;
}

.editor-keyboard-spacer {
  height: 240rpx;
}

.editor-footer {
  position: fixed;
  z-index: 1000;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx 64rpx;
  box-sizing: border-box;
  background: #f1f4f6;
}

.editor-footer__button {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background: #1b2129;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 88rpx;
  text-align: center;
  box-sizing: border-box;
}

.editor-footer__button--disabled {
  opacity: 0.6;
}

.category-sheet {
  min-height: 58vh;
  max-height: 82vh;
  padding: 0 32rpx 56rpx;
  padding-bottom: calc(56rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #f1f4f6;
  box-sizing: border-box;
  overflow: hidden;
}

.category-sheet__header {
  position: relative;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-sheet__close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  color: #424c59;
  font-size: 52rpx;
  line-height: 64rpx;
}

.category-sheet__title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  color: #1b2129;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 48rpx;
}

.category-sheet__add {
  min-width: 72rpx;
  color: #246fe5;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: right;
}

.category-sheet__scroll {
  height: calc(82vh - 160rpx);
  max-height: 960rpx;
}

.category-sheet__notice {
  margin-bottom: 16rpx;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #7b8591;
  font-size: 26rpx;
  line-height: 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-sheet__notice-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  opacity: 0.72;
}

.category-sheet__list {
  border-radius: 16rpx;
  background: #ffffff;
  overflow: hidden;
}

.category-swipe-shell {
  position: relative;
  overflow: hidden;
  background: #ffffff;
  transition: transform 0.18s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.18s ease, border-radius 0.18s ease;
  will-change: transform;
}

.category-swipe-shell + .category-swipe-shell {
  border-top: 1rpx solid #edf0f3;
}

.category-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 240rpx;
  display: flex;
  z-index: 0;
  opacity: 0;
  transition: opacity 0.16s ease;
}

.category-swipe-shell--open .category-actions {
  opacity: 1;
}

.category-swipe-shell--dragging {
  z-index: 5;
  overflow: visible;
  border-radius: 16rpx;
  box-shadow: 0 20rpx 48rpx rgba(27, 33, 41, 0.22);
  transition: box-shadow 0.12s ease, border-radius 0.12s ease;
}

.category-action {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 40rpx;
}

.category-action--delete {
  background: #f55047;
}

.category-action--edit {
  background: #246fe5;
}

.category-row {
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 96rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  transition: transform 0.2s ease;
  box-sizing: border-box;
}

.category-swipe-shell--dragging .category-row {
  border-radius: 16rpx;
}

.category-row--selected .category-row__name {
  color: #246fe5;
  font-weight: 600;
}

.category-row__name {
  flex: 1;
  min-width: 0;
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.category-row__drag {
  width: 56rpx;
  height: 56rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9aa3ad;
  font-size: 30rpx;
  line-height: 56rpx;
  flex-shrink: 0;
}

.category-row__check {
  width: 24rpx;
  height: 14rpx;
  margin-left: 20rpx;
  border-left: 4rpx solid #246fe5;
  border-bottom: 4rpx solid #246fe5;
  transform: rotate(-45deg) translateY(-2rpx);
  box-sizing: border-box;
  flex-shrink: 0;
}

.category-edit-dialog {
  position: fixed;
  z-index: 11000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.category-edit-dialog__mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.7);
}

.category-edit-dialog__panel {
  position: relative;
  width: 100%;
  border-radius: 32rpx;
  overflow: hidden;
  background: #ffffff;
}

.category-edit-dialog__content {
  padding: 52rpx 48rpx;
  box-sizing: border-box;
}

.category-edit-dialog__title {
  color: #1b2129;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 48rpx;
  text-align: center;
}

.category-edit-dialog__tip {
  margin-top: 16rpx;
  color: #626c78;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
}

.category-edit-dialog__input {
  width: 100%;
  height: 84rpx;
  margin-top: 16rpx;
  padding: 0 32rpx;
  border-radius: 8rpx;
  background: #f1f4f6;
  color: #424c59;
  font-size: 28rpx;
  line-height: 44rpx;
  box-sizing: border-box;
}

.category-edit-dialog__actions {
  height: 96rpx;
  display: flex;
  border-top: 1rpx solid #e8ecf0;
}

.category-edit-dialog__button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 48rpx;
}

.category-edit-dialog__button + .category-edit-dialog__button {
  border-left: 1rpx solid #e8ecf0;
}

.category-edit-dialog__button--cancel {
  color: #8b949e;
}

.category-edit-dialog__button--confirm {
  color: #246fe5;
}
