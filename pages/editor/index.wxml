<view class="page-shell">
  <view class="form-card">
    <button class="primary-btn" loading="{{isScanning}}" bindtap="startScan">{{mode === 'edit' ? '重新拍照 / 上传图片' : '拍照 / 上传图片'}}</button>

    <view class="field">
      <text class="field-label">文件名称</text>
      <input class="field-input" placeholder="例如：租房合同扫描件" data-field="name" bindinput="onInput" value="{{name}}" />
    </view>

    <view class="field">
      <text class="field-label">识别内容</text>
      <textarea class="field-textarea" auto-height maxlength="-1" placeholder="扫描后生成的识别文本会显示在这里" data-field="markdown" bindinput="onInput" value="{{markdown}}" />
    </view>

    <button class="primary-btn" style="margin-top: 32rpx;" bindtap="saveDocument">{{mode === 'edit' ? '保存修改' : '保存到首页'}}</button>
  </view>
</view>
