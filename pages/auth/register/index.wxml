<view class="page-shell">
  <view class="hero-card">
    <view class="page-title">创建你的账号</view>
    <view class="page-subtitle">账号体系包含账号、密码、密保问题与密保答案，后续可在个人中心继续修改。</view>
  </view>

  <view class="form-card" style="margin-top: 28rpx;">
    <view class="field">
      <text class="field-label">账号</text>
      <input class="field-input" placeholder="例如：sunlei" data-field="username" bindinput="onInput" value="{{username}}" />
    </view>

    <view class="field">
      <text class="field-label">密码</text>
      <input class="field-input" password placeholder="请输入密码" data-field="password" bindinput="onInput" value="{{password}}" />
    </view>

    <view class="field">
      <text class="field-label">确认密码</text>
      <input class="field-input" password placeholder="请再次输入密码" data-field="confirmPassword" bindinput="onInput" value="{{confirmPassword}}" />
    </view>

    <view class="field">
      <text class="field-label">密保问题</text>
      <input class="field-input" placeholder="例如：我最喜欢的城市是？" data-field="securityQuestion" bindinput="onInput" value="{{securityQuestion}}" />
    </view>

    <view class="field">
      <text class="field-label">密保答案</text>
      <input class="field-input" placeholder="请输入密保答案" data-field="securityAnswer" bindinput="onInput" value="{{securityAnswer}}" />
    </view>

    <button class="primary-btn" style="margin-top: 32rpx;" bindtap="submitRegister">立即创建</button>
  </view>
</view>
