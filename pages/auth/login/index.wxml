<view class="page-shell">
  <view class="hero-card">
    <view class="page-title">欢迎回到 Housely Docs</view>
    <view class="page-subtitle">登录后即可管理扫描生成的 Markdown 文档，支持账号注册、密码找回与个人资料维护。</view>
  </view>

  <view class="form-card" style="margin-top: 28rpx;">
    <view class="field">
      <text class="field-label">账号</text>
      <input class="field-input" placeholder="请输入账号" data-field="username" bindinput="onInput" value="{{username}}" />
    </view>

    <view class="field">
      <text class="field-label">密码</text>
      <input class="field-input" password placeholder="请输入密码" data-field="password" bindinput="onInput" value="{{password}}" />
    </view>

    <button class="primary-btn" style="margin-top: 32rpx;" bindtap="submitLogin">登录</button>

    <view class="link-row">
      <text bindtap="goRegister">创建账号</text>
      <text bindtap="goReset">忘记密码</text>
    </view>
  </view>
</view>
