page {
  background: #f1f4f6;
}

.document-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f1f4f6;
}

.document-navbar {
  flex-shrink: 0;
  background: #f1f4f6;
}

.document-navbar__bar {
  position: relative;
  display: flex;
  align-items: center;
  padding-left: 16px;
  box-sizing: border-box;
}

.document-navbar__back {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  position: relative;
  z-index: 2;
}

.document-navbar__back-icon {
  width: 44rpx;
  height: 44rpx;
}

.document-navbar__title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 320rpx;
  color: #1b2129;
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 600;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.document-navbar__capsule {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 156rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.document-navbar__capsule-inner {
  width: 120rpx;
  height: 56rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(241, 244, 246, 0.9);
}

.document-navbar__capsule-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #1b2129;
}

.document-navbar__capsule-divider {
  width: 2rpx;
  height: 18rpx;
  margin: 0 2rpx 0 6rpx;
  border-radius: 999rpx;
  background: #e8ecf0;
}

.document-navbar__capsule-ring {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 3rpx solid #1b2129;
  box-sizing: border-box;
  position: relative;
}

.document-navbar__capsule-ring::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #1b2129;
  transform: translate(-50%, -50%);
}

.document-toolbar,
.document-searchbar {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.document-toolbar__left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.document-pill {
  min-width: 110rpx;
  height: 72rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #ffffff;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.document-pill__icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.document-pill__text {
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
}

.document-zoom {
  height: 72rpx;
  background: #ffffff;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.document-zoom__button {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.document-zoom__icon {
  width: 34rpx;
  height: 34rpx;
}

.document-zoom__icon--minus,
.document-zoom__icon--plus {
  width: 36rpx;
  height: 36rpx;
}

.document-zoom__divider {
  width: 2rpx;
  height: 24rpx;
  background: #e1e5eb;
}

.document-searchbar {
  gap: 16rpx;
}

.document-searchbar__box {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.document-searchbar__icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.document-searchbar__input {
  flex: 1;
  min-width: 0;
  margin-left: 8rpx;
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
}

.document-searchbar__placeholder {
  color: #8b949e;
  font-size: 28rpx;
  line-height: 44rpx;
}

.document-searchbar__clear {
  margin-left: 12rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.document-searchbar__clear-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.52;
}

.document-searchbar__cancel {
  color: #626c78;
  font-size: 28rpx;
  line-height: 44rpx;
  flex-shrink: 0;
}

.document-scroll {
  flex: 1;
  min-height: 0;
}

.document-scroll__anchor {
  width: 100%;
  height: 0;
}

.document-scroll__body {
  min-height: 100%;
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.document-card {
  flex: 1;
  min-height: 100%;
  width: 100%;
  padding: 24rpx 32rpx 16rpx;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 16rpx 16rpx 0 0;
}

.document-card__title {
  color: #2e3742;
  font-weight: 600;
}

.document-card__title-segment,
.document-card__content-segment {
  color: #2e3742;
}

.document-card__content {
  margin-top: 12rpx;
  color: #2e3742;
}

.document-card__line {
  width: 100%;
  word-break: break-all;
}

.document-card__line--empty {
  display: block;
}

.document-card__segment--matched {
  background: #f7dc67;
  border-radius: 6rpx;
  padding: 0 2rpx;
  color: #2e3742;
}
