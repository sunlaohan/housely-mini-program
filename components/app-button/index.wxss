.app-button {
  margin: 0;
  padding: 0 30rpx;
  height: 88rpx;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.app-button::after {
  display: none;
}

.app-button--full {
  width: 100% !important;
}

.app-button--fixed {
  display: flex;
}

.app-button--dark {
  background: #1b2129 !important;
  color: #ffffff !important;
}

.app-button--light {
  background: #ffffff !important;
  color: #1b2129 !important;
}

.app-button--soft {
  background: #f1f4f6 !important;
  color: #1b2129 !important;
}

.app-button--outline {
  background: #ffffff !important;
  color: #1b2129 !important;
  border: 2rpx solid #e8ecf0;
}

.app-button--danger {
  background: #f55047 !important;
  color: #ffffff !important;
}

.app-button--disabled {
  opacity: 0.6;
}

.app-button__text {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 44rpx;
  display: block;
}
