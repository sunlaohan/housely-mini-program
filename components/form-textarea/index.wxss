.form-textarea {
  width: 100%;
  background: #ffffff;
}

.form-textarea__inner {
  position: relative;
  padding: 20rpx 32rpx;
}

.form-textarea__inner--divider::after {
  content: '';
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: #e1e5eb;
  transform: scaleY(0.5);
  transform-origin: center bottom;
}

.form-textarea__label-row {
  display: flex;
  align-items: center;
  min-height: 44rpx;
  color: #424c59;
  font-size: 28rpx;
  line-height: 44rpx;
}

.form-textarea__required {
  margin-right: 4rpx;
  color: #f55047;
}

.form-textarea__control {
  margin-top: 16rpx;
  width: 100%;
  min-height: 96rpx;
  max-height: 240rpx;
  padding: 0;
  border: none;
  background: transparent;
  color: #1b2129;
  font-size: 28rpx;
  line-height: 44rpx;
  box-sizing: border-box;
}

.form-textarea__placeholder {
  color: #c4c9cf;
}

.form-textarea__count {
  margin-top: 8rpx;
  color: #8b949e;
  font-size: 24rpx;
  line-height: 40rpx;
  text-align: right;
}
