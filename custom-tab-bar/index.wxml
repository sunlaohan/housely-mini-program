<view class="custom-tab-bar {{hidden ? 'custom-tab-bar--hidden' : ''}}">
  <view class="custom-tab-bar__inner">
    <block wx:for="{{list}}" wx:key="pagePath">
      <view class="custom-tab-bar__item" data-index="{{index}}" data-path="{{item.pagePath}}" bindtap="onSwitchTab">
        <view class="custom-tab-bar__icon-wrap">
          <image
            class="custom-tab-bar__icon {{selected === index ? '' : 'custom-tab-bar__icon--visible'}}"
            src="{{item.iconPath}}"
            mode="aspectFit"
          />
          <image
            class="custom-tab-bar__icon {{selected === index ? 'custom-tab-bar__icon--visible' : ''}}"
            src="{{item.selectedIconPath}}"
            mode="aspectFit"
          />
        </view>
        <text class="custom-tab-bar__label {{selected === index ? 'custom-tab-bar__label--active' : ''}}">
          {{item.text}}
        </text>
      </view>
    </block>
  </view>
</view>
